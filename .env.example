# =============================================================================
# Infisical — secrets backend
# Docs: https://infisical.com/docs/documentation/platform/identities/universal-auth
# =============================================================================

# Universal Auth machine identity credentials
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=

# Infisical site URL — omit to use cloud (https://app.infisical.com)
INFISICAL_SITE_URL=

# Project and environment to pull secrets from
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev

# Secret path within the project (defaults to /)
INFISICAL_SECRET_PATH=/

# =============================================================================
# clix daemon
# =============================================================================

# Unix socket path for `clix serve --socket` and `clix client`
CLIX_SOCKET=/tmp/clix.sock

# HTTP listen address for `clix serve --http`
CLIX_HTTP_ADDR=127.0.0.1:8080

# clix home directory (defaults to ~/.clix)
# CLIX_HOME=

# =============================================================================
# Approval gate — human-in-the-loop webhook
# =============================================================================

# Webhook URL that receives ApprovalRequest JSON POSTs
# Leave empty to return approvalRequired:true immediately (legacy mode)
CLIX_APPROVAL_WEBHOOK_URL=

# Seconds to wait for a human response before auto-denying (default 300)
CLIX_APPROVAL_TIMEOUT_SECONDS=300

# Optional bearer token sent as Authorization header with approval requests
CLIX_APPROVAL_WEBHOOK_TOKEN=

# =============================================================================
# Sandbox (Landlock exec enforcement, Linux 5.13+ only)
# =============================================================================

# Set to "1" to fail hard if Landlock is unavailable instead of warn-and-run
CLIX_SANDBOX_REQUIRE_LANDLOCK=0

# =============================================================================
# Logging / observability
# =============================================================================

# Log level: debug, info, warn, error (default: info)
CLIX_LOG_LEVEL=info

# Pretty-print JSON output (default: false — newline-delimited JSON)
CLIX_LOG_PRETTY=false
